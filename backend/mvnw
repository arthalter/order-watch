# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
#
# Optional ENV vars
# -----------------
#   JAVA_HOME - location of a JDK home dir
#   MVNW_REPOURL - repo url base for downloading maven distributions
#   MVNW_VERBOSE - true: enable verbose log; debug: debug log; others: quiet
# ----------------------------------------------------------------------------

set -euf

[ "${MVNW_VERBOSE-}" = debug ] && set -x

if [ -z "${JAVA_HOME-}" ]; then
  JAVA_EXE="$(command -v java || true)"
else
  JAVA_EXE="$JAVA_HOME/bin/java"
fi

if [ -z "${JAVA_EXE-}" ]; then
  echo "Error: JAVA_HOME is not set and no 'java' command could be found in your PATH." 1>&2
  exit 1
fi

BASEDIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)

WRAPPER_DIR="$BASEDIR/.mvn/wrapper"
WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"
WRAPPER_PROPS="$WRAPPER_DIR/maven-wrapper.properties"

download_wrapper_jar() {
  if [ ! -f "$WRAPPER_PROPS" ]; then
    echo "Error: Missing $WRAPPER_PROPS" 1>&2
    exit 1
  fi

  WRAPPER_URL=$(grep -E '^wrapperUrl=' "$WRAPPER_PROPS" | sed 's/^wrapperUrl=//')
  if [ -z "${WRAPPER_URL-}" ]; then
    WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
  fi

  mkdir -p "$WRAPPER_DIR"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    echo "Error: Need either curl or wget to download $WRAPPER_URL" 1>&2
    exit 1
  fi
}

if [ ! -f "$WRAPPER_JAR" ]; then
  download_wrapper_jar
fi

exec "$JAVA_EXE" \
  -classpath "$WRAPPER_JAR" \
  -Dmaven.multiModuleProjectDirectory="$BASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain "$@"

